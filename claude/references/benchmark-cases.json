{
  "version": "1.0",
  "created": "2026-06-08",
  "description": "Curated benchmark cases derived from agent_outputs/ ground-truth runs. Each case represents a fully evaluated and validated BioThings data plugin.",
  "cases": [
    {
      "case_id": "ecbd",
      "case_name": "ECBD (European Chemical Biology Database)",
      "tags": ["core", "plugin"],
      "stages": ["relevancy", "site_inspection", "plugin"],
      "test_prompt": "Evaluate ECBD (European Chemical Biology Database) from https://ecbd.eu — a collection of EU-OPENSCREEN small molecule compounds for BioThings ingest.",
      "ground_truth": {
        "relevancy": {
          "verdict": "RECOMMEND_INGEST",
          "relevance_score": 5,
          "novelty_score": 3,
          "openness_verdict": "PASS",
          "openness_score": 4,
          "license": "CC BY 4.0"
        },
        "site_inspection": {
          "status": "VERIFIED",
          "download_accessible": true,
          "primary_key_field": "inchikey",
          "target_api": "MyChem.info",
          "ssl_workaround_required": true,
          "total_unique_docs": 108822
        },
        "plugin": {
          "min_documents": 100000,
          "id_format": "InChIKey",
          "id_pattern": "^[A-Z]{14}-[A-Z]{10}-[A-Z]$",
          "novel_fields": ["eos", "smiles", "inchi", "formula", "mw", "hba", "hbd", "tpsa", "rb", "fp3", "logp", "violates_ro5", "sub_library"],
          "on_duplicates": "error",
          "license_expected": "CC BY 4.0"
        }
      },
      "source_artifacts": {
        "relevancy": "agent_outputs/ecbd_datasource/ecbd_relevancy.json",
        "site_inspection": "agent_outputs/ecbd_datasource/ecbd_inspection.json",
        "plugin_dir": "agent_outputs/ecbd_datasource/ecbd_plugin"
      },
      "notes": "Self-signed TLS on ecbd.eu requires --insecure workaround for dump. 34 cross-file duplicate InChIKeys handled via seen_ids dedup in parser."
    },
